{
  "nodes": [
    {
      "types": [
        "Join"
      ],
      "alias": "converge",
      "properties": {
        "skill": "graph.join"
      }
    },
    {
      "types": [
        "mapper"
      ],
      "alias": "data-mapper",
      "properties": {
        "mapping": [
          "text(Y) -> model.a[]",
          "text(Y) -> model.a[]",
          "text(N) -> model.a[]"
        ],
        "skill": "graph.data.mapper"
      }
    },
    {
      "types": [
        "End"
      ],
      "alias": "end",
      "properties": {}
    },
    {
      "types": [
        "Fetcher"
      ],
      "alias": "fetcher",
      "properties": {
        "output": [
          "result.person_name -> output.body.name",
          "result.person_address -> output.body.address",
          "result.person_accounts -> output.body.accounts",
          "text(world) -> output.header.x-hello"
        ],
        "input": [
          "input.body.person_id -> person_id"
        ],
        "dictionary": [
          "person-name",
          "person-address",
          "person-accounts"
        ],
        "skill": "graph.api.fetcher",
        "error": "break"
      }
    },
    {
      "types": [
        "Extension"
      ],
      "alias": "flowext",
      "properties": {
        "input": [
          "input.body.person_id -> id"
        ],
        "extension": "flow://echo",
        "skill": "graph.extension"
      }
    },
    {
      "types": [
        "Math"
      ],
      "alias": "js-1",
      "properties": {
        "skill": "graph.math",
        "statement": [
          "COMPUTE: isHello[] -> {model.item} == 'hello'"
        ],
        "for_each": [
          "model.none -> model.items",
          "text(hello) -> model.items[]",
          "text(world) -> model.items[]",
          "model.items -> model.item"
        ]
      }
    },
    {
      "types": [
        "JavaScript"
      ],
      "alias": "js-2",
      "properties": {
        "skill": "graph.js",
        "statement": [
          "COMPUTE: positive_items -> {model.item} == 'Y'",
          "COMPUTE: negative_items -> {model.item} != 'Y'"
        ],
        "for_each": [
          "model.a -> model.item"
        ]
      }
    },
    {
      "types": [
        "JavaScript"
      ],
      "alias": "js-3",
      "properties": {
        "skill": "graph.js",
        "statement": [
          "COMPUTE: positive_items -> {model.a}.filter(item => item== 'Y')",
          "COMPUTE: negative_items -> {model.a}.filter(item => item!= 'Y')",
          "COMPUTE: test -> var x = {name:'Alice', age: 30, nested: {'inner': {model.a}}, tags: ['a','b']}; x;",
          "COMPUTE: y -> 3 * 4",
          "COMPUTE: z -> var x = 3 * 4.02; x.toFixed(3);"
        ]
      }
    },
    {
      "types": [
        "Math"
      ],
      "alias": "js-4",
      "properties": {
        "skill": "graph.math",
        "statement": [
          "COMPUTE: x -> 3 * 100",
          "RESET: js-4"
        ]
      }
    },
    {
      "types": [
        "Provider"
      ],
      "alias": "mdm-profile",
      "properties": {
        "input": [
          "text(application/json) -> header.accept",
          "person_id -> path_parameter.id"
        ],
        "feature": [
          "oauth-bearer",
          "log-request-headers",
          "log-response-headers"
        ],
        "method": "GET",
        "purpose": "profile management endpoint",
        "url": "http://127.0.0.1:${rest.server.port}/api/mdm/profile/{id}"
      }
    },
    {
      "types": [
        "Dictionary"
      ],
      "alias": "person-accounts",
      "properties": {
        "output": [
          "response.accounts -> result.person_accounts"
        ],
        "input": [
          "person_id"
        ],
        "provider": "mdm-profile",
        "purpose": "accounts of a person"
      }
    },
    {
      "types": [
        "Dictionary"
      ],
      "alias": "person-address",
      "properties": {
        "output": [
          "response.profile.address -> result.person_address"
        ],
        "input": [
          "person_id"
        ],
        "provider": "mdm-profile",
        "purpose": "address of a person"
      }
    },
    {
      "types": [
        "Dictionary"
      ],
      "alias": "person-name",
      "properties": {
        "output": [
          "response.profile.name -> result.person_name"
        ],
        "input": [
          "person_id"
        ],
        "purpose": "name of a person",
        "provider": "mdm-profile"
      }
    },
    {
      "types": [
        "Root"
      ],
      "alias": "root",
      "properties": {
        "purpose": "Demo Graph Model",
        "name": "helloworld"
      }
    }
